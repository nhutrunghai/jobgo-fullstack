# App
PORT=4000
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
BUILD_MODE=dev

# Database
# Local native run:
# DB_URL=mongodb://127.0.0.1:27017/jobgo
# Docker compose hiện tại override DB_URL thành:
# mongodb://host.docker.internal:27017/jobgo
DB_URL=mongodb://127.0.0.1:27017/jobgo
DB_NAME=jobgo
DB_USER_NAME=users
DB_COMPANY_NAME=companies
DB_JOB_NAME=jobs
DB_FAVORITE_JOB_NAME=favorite_jobs
DB_RESUME_NAME=resumes
DB_JOB_APPLICATION_NAME=job_applications
DB_REFRESH_TOKEN_NAME=refresh_tokens
DB_OTP_CODE_NAME=otp_codes

# JWT
SECRET_ACCESS_TOKEN=replace_with_a_32_plus_char_secret
SECRET_REFRESH_TOKEN=replace_with_a_32_plus_char_secret
ExpiresIn_ACCESS_TOKEN=5m
ExpiresIn_REFRESH_TOKEN=7 days
ExpiresIn_EMAIL_VERIFY_TOKEN=24h
ExpiresIn_FORGOT_PASSWORD_TOKEN=15m

# Redis
# Local native run:
# REDIS_HOST=127.0.0.1
# Docker compose hiện tại override:
# REDIS_HOST=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Mail / Resend
RESEND_API_KEY=your_resend_api_key
MAIL_FROM_ADDRESS=example.com
MAIL_FROM_NAME=JOBGO

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URL=http://localhost:4000/api/v1/auth/oauth/google

# Search
# Local native run:
# ELASTICSEARCH_URL=http://localhost:9200
# Docker compose hiện tại override:
# ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_URL=http://localhost:9200
PUBLIC_JOBS_SEARCH_INDEX=public_jobs_search

# Embedding service
# Nếu chạy local native:
# EMBEDDING_API_URL=http://localhost:8000
# Docker compose hiện tại override:
# EMBEDDING_API_URL=http://embedding-api:8000
EMBEDDING_API_URL=http://localhost:8000

# Optional model providers
HUGGINGFACE_API_KEY=your_huggingface_api_key
GEMINI_API_KEY=your_gemini_api_key

# Admin session
ADMIN_SESSION_COOKIE_NAME=admin_sid
ADMIN_SESSION_PREFIX=admin:sessions
ADMIN_SESSION_TTL=1800
ADMIN_COOKIE_SECURE=false
ADMIN_COOKIE_SAME_SITE=lax
